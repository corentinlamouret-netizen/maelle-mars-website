# Security Configuration
# Copy this file to .env and update the values for your environment

# Allowed Origins for CORS (comma-separated)
# In development: http://localhost:3000,http://localhost:3001,http://localhost:5173
# In production: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Rate Limiting Configuration
# General rate limit: 100 requests per 15 minutes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth rate limit: 5 requests per 15 minutes
AUTH_RATE_LIMIT_MAX=5

# API rate limit: 30 requests per minute
API_RATE_LIMIT_MAX=30

# Session Configuration
# Session cookie max age in milliseconds (default: 24 hours)
SESSION_MAX_AGE=86400000

# Security Headers
# Enable/disable specific security headers
ENABLE_CSP=true
ENABLE_HSTS=true
ENABLE_FRAMEGUARD=true
ENABLE_NOSNIFF=true
ENABLE_XSS_FILTER=true

# Logging
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable security event logging
ENABLE_SECURITY_LOGGING=true

# HTTPS Configuration
# Redirect HTTP to HTTPS in production
FORCE_HTTPS=true

# Database Security
# Use SSL for database connections
DB_USE_SSL=true

# API Security
# Require API key for certain endpoints
REQUIRE_API_KEY=false
API_KEY_HEADER=X-API-Key
